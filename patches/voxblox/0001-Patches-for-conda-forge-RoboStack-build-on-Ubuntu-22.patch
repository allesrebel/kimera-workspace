diff --git a/voxblox_rviz_plugin/CMakeLists.txt b/voxblox_rviz_plugin/CMakeLists.txt
index 5b8442c..e3e7512 100644
--- a/voxblox_rviz_plugin/CMakeLists.txt
+++ b/voxblox_rviz_plugin/CMakeLists.txt
@@ -5,7 +5,9 @@ find_package(catkin_simple REQUIRED)
 catkin_simple(ALL_DEPS_REQUIRED)
 
 set(CMAKE_MACOSX_RPATH 0)
-add_definitions(-std=c++11 -Wall)
+add_definitions(-std=c++17 -Wall -DGLOG_USE_GLOG_EXPORT)
+set(CMAKE_CXX_STANDARD 17)
+set(CMAKE_CXX_STANDARD_REQUIRED ON)
 
 ## This setting causes Qt's "MOC" generation to happen automatically.
 set(CMAKE_AUTOMOC ON)
